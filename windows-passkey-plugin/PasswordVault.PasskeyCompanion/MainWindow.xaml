<Window x:Class="PasswordVault.PasskeyCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Password Vault Passkey Companion"
        Width="1100"
        Height="820"
        MinWidth="900"
        MinHeight="680"
        Background="#0F1720"
        Foreground="#F8FAFC"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#18212B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111926" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#223041" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34D399" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="TagStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="#243142" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="MetaLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#93A4B7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MetaValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="30"
                        Padding="28"
                        Background="#121D2A"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Password Vault Passkey Companion"
                                       FontSize="32"
                                       FontWeight="Bold" />
                            <TextBlock Text="A dedicated Windows companion scaffold for the third-party passkey manager / plugin route."
                                       Margin="0,10,0,0"
                                       Foreground="#94A3B8"
                                       FontSize="15"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <Border Style="{StaticResource TagStyle}"
                                        Background="{Binding StatusTagBackground}">
                                    <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource TagStyle}" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding CheckedAtText}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="112"
                                Height="42"
                                Margin="18,0,0,0"
                                VerticalAlignment="Top"
                                Click="RefreshButton_Click"
                                Background="{StaticResource AccentBrush}"
                                BorderThickness="0"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Content="Refresh" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Readiness" />
                        <TextBlock Text="{Binding DetailMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#C9D4E2"
                                   FontSize="15" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Environment" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,18,18">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="Windows build" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}" Text="{Binding WindowsBuildText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,0,18">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="Packaged process" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}" Text="{Binding PackagedText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,18,0">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="webauthn.dll" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}" Text="{Binding WebAuthnText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="Plugin exports" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}" Text="{Binding PluginExportsText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Margin="0,18,18,0">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="Package family name" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}"
                                                   Text="{Binding PackageFamilyNameText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,18,0,0">
                                        <TextBlock Style="{StaticResource MetaLabelStyle}" Text="Package full name" />
                                        <TextBlock Style="{StaticResource MetaValueStyle}"
                                                   Text="{Binding PackageFullNameText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Planned responsibilities" />
                                <ItemsControl ItemsSource="{Binding Responsibilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SubtleBrush}"
                                                    CornerRadius="18"
                                                    Padding="14"
                                                    Margin="0,0,0,10">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#E2E8F0"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Missing plugin exports" />
                                <ItemsControl ItemsSource="{Binding MissingExports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2A1820"
                                                    CornerRadius="18"
                                                    Padding="12"
                                                    Margin="0,0,0,10">
                                                <TextBlock Text="{Binding}" Foreground="#FECACA" TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding MissingExportsEmptyText}"
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Next steps" />
                                <ItemsControl ItemsSource="{Binding NextSteps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SubtleBrush}"
                                                    CornerRadius="18"
                                                    Padding="14"
                                                    Margin="0,0,0,10">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#E2E8F0"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
